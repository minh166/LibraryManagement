@model List<ClientWeb.Models.BookViewModel>

@{
    ViewData["Title"] = "Trang chủ";
    var role = Context.Session.GetInt32("Role");
    var userId = Context.Session.GetInt32("UserId");
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📚 Danh sách sách</h2>

        @if (role == 2)  
        {
            <a asp-action="Create" class="btn btn-success">+ Thêm sách</a>
        }
    </div>

    <!-- ALERT -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <!-- SEARCH -->
    <form method="get" class="mb-3">
        <div class="input-group">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control" placeholder="Tìm theo tên sách, tác giả..." />
            <button type="submit" class="btn btn-primary">Tìm</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Xóa lọc</a>
        </div>
    </form>

    <!-- TABLE -->
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Tên sách</th>
                <th>Tác giả</th>
                <th>Thể loại</th>
                <th>Tổng SL</th>
                <th>Còn lại</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var book in Model)
            {
                <tr>
                    <td>@book.Id</td>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>@book.CategoryName</td>
                    <td>@book.TotalQuantity</td>
                    <td>@book.AvailableQuantity</td>

                    <!-- STATUS -->
                    <td>
                        @if (book.AvailableQuantity > 0)
                        {
                            <span class="badge bg-success">Còn sách</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Hết sách</span>
                        }
                    </td>

                    <td>
                        @if (role == 2)
                        {
                            <a asp-action="Edit" asp-route-id="@book.Id"
                               class="btn btn-sm btn-warning">Sửa</a>

                            <form asp-action="Delete" asp-route-id="@book.Id"
                                  method="post" style="display:inline"
                                  onsubmit="return confirm('Xóa sách này?')">
                                <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                            </form>
                        }

                        @if (role == 3)
                        {
                            if (book.AvailableQuantity > 0)
                            {
                                <form asp-controller="Borrows" asp-action="BorrowBook"
                                      method="post" style="display:inline">
                                    <input type="hidden" name="bookId" value="@book.Id" />
                                    <button type="submit" class="btn btn-sm btn-primary">
                                        📖 Mượn
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-secondary" disabled>
                                    Hết sách
                                </button>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>