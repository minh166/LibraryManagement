@model ClientWeb.Models.BorrowViewModel

@{
    ViewData["Title"] = "Gia hạn sách";
}

<div class="container mt-4">
    <h2>🔄 Gia hạn mượn sách</h2>
    <hr />

    <div class="card mb-3" style="max-width:500px">
        <div class="card-body">
            <p><strong>Sách:</strong> @Model.BookTitle</p>
            <p><strong>Hạn trả hiện tại:</strong> @Model.DueDate.ToString("dd/MM/yyyy")</p>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <form asp-action="Extend" asp-route-id="@Model.Id"
          method="post" style="max-width:500px">
        <div class="mb-3">
            <label class="form-label">Ngày gia hạn mới</label>
            <input type="date" name="newDueDate" class="form-control"
                   min="@Model.DueDate.AddDays(1).ToString("yyyy-MM-dd")" required />
        </div>
        <button type="submit" class="btn btn-warning">Gia hạn</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
    </form>
</div>