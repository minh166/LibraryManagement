<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClientWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ClientWeb.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">📖 Library</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @{
                        var role = Context.Session.GetInt32("Role");
                        var userId = Context.Session.GetInt32("UserId");
                    }

                    @if (userId != null)
                    {
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">🏠 Home</a>
                            </li>

                            @if (role == 1)
                            {
                                <!-- Admin -->
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="User" asp-action="Index">👥 Người dùng</a>
                                </li>
                            }
                            else if (role == 2)
                            {
                                <!-- Thủ thư -->
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Books" asp-action="Index">📚 Sách</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Borrows" asp-action="Index">📋 Mượn sách</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Fines" asp-action="Index">💰 Phạt</a>
                                </li>
                            }
                            else if (role == 3)
                            {
                                <!-- Độc giả -->
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Books" asp-action="Index">📚 Sách</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Borrows" asp-action="MyBorrows">📋 Mượn của tôi</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Fines" asp-action="MyFines">💰 Phạt của tôi</a>
                                </li>
                            }
                        </ul>

                        <!-- Hiện username + nút logout -->
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <span class="nav-link text-muted">
                                    👤 @Context.Session.GetString("Username")
                                    @(role == 1 ? "(Admin)" : role == 2 ? "(Thủ thư)" : "(Độc giả)")
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Auth" asp-action="Logout">🚪 Đăng xuất</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Library Management
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>